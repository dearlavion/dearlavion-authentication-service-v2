# HTTP
PORT=9081

# Multi-tenancy — comma-separated allowlist of customers this instance serves.
# Each maps to its own `authentication-<customer>` DB (selected per request via X-Customer / token).
CUSTOMERS=dearlavion

# Provisioning — secret required (X-Provision-Secret header) to assign the ADMIN/STAFF role at
# register/patch. Leave empty to disable privileged-role assignment via the API entirely.
PROVISION_SECRET=

# MongoDB — base connection; each request routes to authentication-<customer> via useDb().
MONGODB_URI=mongodb://localhost:27017/authentication-service

# JWT — base64-encoded HMAC key. MUST match the Java v1 key so tokens interoperate across stacks.
JWT_SECRET=5B6F7D3E2A9C4B8E0A1F6D9B3E7A2C9D4F8E5B6C3A7B1D6F4C9A3E8D2B5F7A1
JWT_EXPIRES_IN=24h
JWT_RESET_EXPIRES_IN=15m

# Kafka
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=dearlavion-authentication-service-v2

# Google OAuth
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=758689020846-n81t9f9mut3mmh5jtd4fudn50d8gq87m.apps.googleusercontent.com
